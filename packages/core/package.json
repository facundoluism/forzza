{
  "name": "@forzza/core",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:webhooks": "cross-env RUN_DB_TESTS=1 vitest run --coverage --coverage.include=src/billing/mp*.ts --coverage.include=src/billing/mock-mercadopago.ts --coverage.thresholds.lines=80 --coverage.thresholds.functions=80 --coverage.thresholds.branches=80 --coverage.thresholds.statements=80 src/billing/__tests__/mp-pure.test.ts src/billing/__tests__/mp-webhook-idempotency.test.ts",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint src/"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@forzza/eslint-config": "workspace:*",
    "@forzza/tsconfig": "workspace:*",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.8",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "pg": "^8.13.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
