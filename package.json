{
  "name": "forzza",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "turbo run dev --filter=mobile",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:rls": "node scripts/test-rls.js",
    "test:webhooks": "pnpm --filter @forzza/core run test:webhooks",
    "e2e": "pnpm exec playwright test --config e2e/playwright/playwright.config.ts",
    "e2e:turbo": "turbo run e2e",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "db:reset": "node scripts/db-reset.js",
    "db:types": "node scripts/db-types.js",
    "clean": "turbo run clean && node scripts/clean.js",
    "validate-env": "node scripts/validate-env.js",
    "smoke-test": "node scripts/smoke-test.js",
    "smoke-test:fixtures": "cross-env SMOKE_EXPECT_FIXTURES=1 node scripts/smoke-test.js",
    "smoke-test:mobile": "maestro test e2e/flows/03-workout-session.yaml",
    "smoke-test:staging": "node scripts/smoke-test.js --url https://staging.forzza.app",
    "videos:generate": "tsx scripts/build-exercise-videos.ts",
    "videos:generate:dry": "tsx scripts/build-exercise-videos.ts --dry-run",
    "videos:push-cloud": "node scripts/push-videos-cloud.js",
    "icons:backfill": "tsx scripts/backfill-svg-icons.ts",
    "icons:backfill:dry": "tsx scripts/backfill-svg-icons.ts --dry-run"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.19.20",
    "cross-env": "^10.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "react-native": "0.81.5",
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "~19.1.10"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.34.2"
}
