# Windows: aplanar node_modules para que las rutas de los .cpp.o nativos (RN/Expo)
# no superen el limite CMAKE_OBJECT_PATH_MAX (~250). El layout .pnpm anidado
# rompe la compilacion nativa de Android en Windows. Ver smoke-test mobile.
node-linker=hoisted
virtual-store-dir=../.pnpm
virtual-store-dir-max-length=60
