{
  "expo": {
    "name": "Forzza",
    "slug": "forzza",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "forzza",
    "userInterfaceStyle": "dark",
    "platforms": ["ios", "android"],
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.forzza.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.forzza.app"
    },
    "plugins": ["expo-router"]
  }
}
