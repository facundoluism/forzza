# =============================================================================
# FORZZA — Variables de entorno
# Copiar a .env y completar. .env NUNCA se commitea.
# MOCK_OK=true → la variable tiene mock implementado y no bloquea el dev local
# =============================================================================

# --- Supabase ---
# Obtener en: supabase.com → proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=           # https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # anon/public key
SUPABASE_SERVICE_ROLE_KEY=          # service_role key (solo server/Edge Functions)
SUPABASE_DB_PASSWORD=               # password del proyecto Supabase
DATABASE_URL=                       # postgresql://postgres:password@...

# --- Mercado Pago ---
# Obtener en: mercadopago.com → Mi negocio → Credenciales → Modo producción/test
MP_ACCESS_TOKEN=                    # TEST-xxx... para dev / PROD para producción
MP_WEBHOOK_SECRET=                  # HUMAN_REQUIRED: secreto HMAC-SHA256 para validar x-signature de webhooks MP
                                    # Obtener en: mercadopago.com → Tu negocio → Webhooks → Notificaciones → Clave secreta
                                    # Si falta en producción el endpoint devuelve 500 (fallo ruidoso intencional)
MOCK_MP_WEBHOOK_SECRET=mock-webhook-secret-for-tests
                                    # Secret para MockMercadoPago en tests locales.
                                    # NUNCA usar en producción. Seteado con valor por defecto si no está.
MOCK_SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
                                    # URL del Postgres local para tests de integración de webhook.
                                    # Override con SUPABASE_DB_URL si usás otro puerto.
MOCK_OK=true                        # MockMercadoPago implementado: packages/core/src/billing/mock-mercadopago.ts
                                    # Cubre: createPreapprovalPlan, getPreapproval, generateWebhookHeaders (firma HMAC-SHA256)

# --- RevenueCat ---
# Obtener en: app.revenuecat.com → proyecto → [app] → API Keys
REVENUECAT_APPLE_SHARED_SECRET=     # App Store shared secret (para webhooks server-side)
REVENUECAT_GOOGLE_SERVICE_ACCOUNT=  # JSON credentials de Google Play (para webhooks server-side)
NEXT_PUBLIC_REVENUECAT_API_KEY=     # public key para web (RC Billing — no usado en V1)
# HUMAN_REQUIRED: obtener en app.revenuecat.com → proyecto → Apps → [iOS app] → API Keys → Public SDK Key
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=    # appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HUMAN_REQUIRED: obtener en app.revenuecat.com → proyecto → Apps → [Android app] → API Keys → Public SDK Key
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY= # goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_ENABLE_REVENUECAT_IAP=false # true solo para QA sandbox / builds de tienda con productos IAP configurados
# HUMAN_REQUIRED: secreto para validar webhooks de RevenueCat (Bearer token).
# Obtener en: app.revenuecat.com → Project → Integrations → Webhooks → Authorization header (elegís vos el valor).
# Configurar con: supabase secrets set REVENUECAT_WEBHOOK_SECRET=<valor>
# El mismo valor va en el campo "Authorization header" del webhook en RC dashboard.
REVENUECAT_WEBHOOK_SECRET=          # HUMAN_REQUIRED
MOCK_OK=true                        # MockRevenueCat disponible para dev

# --- Resend (emails) ---
# Obtener en: resend.com → API Keys
RESEND_API_KEY=                     # re_xxx...
RESEND_FROM_EMAIL=noreply@forzza.com
MOCK_OK=true                        # MockEmail (log a consola) disponible para dev

# --- PostHog (analytics) ---
# Obtener en: eu.posthog.com → Project → Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_MOCK_OK
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
EXPO_PUBLIC_POSTHOG_KEY=phc_MOCK_OK
EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
MOCK_OK=true                        # Si falta, PostHog se silencia (no bloquea)

# --- Sentry (errores) ---
# Obtener en: sentry.io → proyecto → Settings → SDK
NEXT_PUBLIC_SENTRY_DSN=https://mock@sentry.io/MOCK_OK
EXPO_PUBLIC_SENTRY_DSN=https://mock@sentry.io/MOCK_OK
SENTRY_AUTH_TOKEN=                  # para source maps en CI
MOCK_OK=true                        # Si falta, Sentry se silencia (no bloquea)

# --- Auth social (OAuth) ---
# Obtener en: developer.apple.com / console.cloud.google.com
# Activar con FEATURE_FLAGS.APPLE_SIGN_IN / GOOGLE_SIGN_IN en packages/config
APPLE_CLIENT_ID=                    # HUMAN_REQUIRED: Apple Developer Program
APPLE_TEAM_ID=                      # HUMAN_REQUIRED: Apple Developer Program
GOOGLE_CLIENT_ID=                   # HUMAN_REQUIRED: Google Cloud Console

# --- Entorno ---
NODE_ENV=development
